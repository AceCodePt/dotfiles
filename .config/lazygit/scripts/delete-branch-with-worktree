#!/bin/bash
# delete-branch-with-worktree - Delete a git branch and its associated worktree
# Usage: delete-branch-with-worktree <branch-name>
#
# This script:
# 1. Runs pre-branch-delete hook (if exists) - for cleanup before deletion
# 2. Removes the worktree for the branch
# 3. Deletes the branch
# 4. Runs post-branch-delete hook (if exists) - for tasks after deletion
#
# Project-specific hooks:
#   <project-root>/hooks/pre-branch-delete  - Runs before deletion (e.g., database cleanup)
#   <project-root>/hooks/post-branch-delete - Runs after deletion (e.g., notifications)
#   Both receive: BRANCH_NAME, WORKTREE_PATH as environment variables

set -e

BRANCH_NAME="$1"

if [ -z "$BRANCH_NAME" ]; then
  echo "❌ Error: Branch name required"
  echo "Usage: $0 <branch-name>"
  exit 1
fi

echo ""
echo "🗑️  Deleting branch: $BRANCH_NAME"
echo ""

# Get project root (parent directory containing all worktrees)
GIT_COMMON_DIR="$(git rev-parse --git-common-dir 2>/dev/null || echo "")"
if [ -n "$GIT_COMMON_DIR" ]; then
  # For bare repos: /path/to/repo.git -> /path/to
  # For worktrees: /path/to/repo.git/worktrees/name -> /path/to
  PROJECT_ROOT="$(dirname "$GIT_COMMON_DIR")"
else
  # Fallback to show-toplevel
  PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || echo "")"
fi

# Find worktree for this branch
WORKTREE_PATH=""
if git worktree list &>/dev/null; then
  # Use simple grep on worktree list output (format: path hash [branch])
  WORKTREE_PATH=$(git worktree list | grep "\[$BRANCH_NAME\]" | awk '{print $1}' || echo "")
fi

# Step 1: Run project-specific cleanup hook (if exists)
if [ -n "$PROJECT_ROOT" ]; then
  CLEANUP_HOOK="$PROJECT_ROOT/hooks/pre-branch-delete"
  
  if [ -x "$CLEANUP_HOOK" ]; then
    echo "🔧 Running project cleanup hook..."
    
    export BRANCH_NAME="$BRANCH_NAME"
    export WORKTREE_PATH="$WORKTREE_PATH"
    
    # Run in foreground (not background) to ensure cleanup completes
    if bash "$CLEANUP_HOOK"; then
      echo "✅ Cleanup hook completed"
    else
      echo "⚠️  Cleanup hook failed (continuing anyway)"
    fi
    echo ""
  fi
fi

# Step 2: Remove worktree if found
if [ -n "$WORKTREE_PATH" ] && [ -d "$WORKTREE_PATH" ]; then
  echo "📁 Removing worktree: $WORKTREE_PATH"
  
  if git worktree remove "$WORKTREE_PATH" --force 2>/dev/null; then
    echo "✅ Worktree removed"
  else
    echo "⚠️  Git worktree remove failed, removing directory manually..."
    rm -rf "$WORKTREE_PATH"
    echo "✅ Worktree removed manually"
  fi
fi

echo ""


# Step 3: Delete the branch
echo "🗑️  Deleting branch: $BRANCH_NAME"
if git branch -D "$BRANCH_NAME" 2>/dev/null; then
  echo "✅ Branch deleted"
else
  echo "❌ Failed to delete branch"
  exit 1
fi

echo ""

# Step 4: Run post-branch-delete hook (if exists)
if [ -n "$PROJECT_ROOT" ]; then
  POST_HOOK="$PROJECT_ROOT/hooks/post-branch-delete"
  
  if [ -x "$POST_HOOK" ]; then
    echo "🔧 Running post-delete hook..."
    
    export BRANCH_NAME="$BRANCH_NAME"
    export WORKTREE_PATH="$WORKTREE_PATH"
    
    if bash "$POST_HOOK"; then
      echo "✅ Post-delete hook completed"
    else
      echo "⚠️  Post-delete hook failed"
    fi
    echo ""
  fi
fi

echo "✅ Complete!"
echo ""
